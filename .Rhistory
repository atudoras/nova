list.files("R", pattern = "\\.R$", full.names = TRUE) |>
lapply(function(f) {
lines <- readLines(f)
matches <- grep("Process data", lines, ignore.case = TRUE)
if(length(matches) > 0) {
cat("\nFile:", f, "\n")
cat("Lines:", matches, "\n")
cat(lines[matches], sep = "\n")
}
})
